---
interface Props {
  theme: 'think' | 'lead' | 'create'
}

const { theme } = Astro.props

const bgColors = {
  think: '#c8d5c0',
  lead: '#d5dde6',
  create: '#e8e4de',
}
---
<footer class="im-footer" style={`background: ${bgColors[theme]}`}>
    <p class="prompt">Let's talk about how things should work.</p>
    <div class="links">
        <a href="mailto:hello@janicequach.com">email</a>
        <a href="https://linkedin.com/in/janicequach" target="_blank" rel="noopener noreferrer">linkedin</a>
    </div>
    <p class="personal">Painter, dancer, chihuahua owner, coffee dependent.</p>
    <p class="colophon">Designed by me, built with Claude.</p>
    <a class="home-link" href="/" aria-label="Back to home">← back to home</a>
</footer>

<style>
    .im-footer {
        padding: 6rem 2rem;
        text-align: center;
    }

    .prompt {
        font-size: 0.85rem;
        font-weight: 300;
        margin-bottom: 1.5rem;
        opacity: 0.5;
    }

    .links {
        display: flex;
        gap: 2rem;
        justify-content: center;
        margin-bottom: 2rem;
    }

    .links a, .home-link {
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        text-transform: lowercase;
        text-decoration: none;
        color: inherit;
        opacity: 0.5;
        border-bottom: 1px solid currentColor;
        padding-bottom: 2px;
        transition: opacity 0.3s;
    }

    .links a:hover, .home-link:hover { opacity: 0.8; }

    .personal {
        font-size: 0.7rem;
        font-weight: 300;
        opacity: 0.5;
        margin-bottom: 0.5rem;
    }

    .colophon {
        font-size: 0.65rem;
        font-weight: 300;
        opacity: 0.45;
        margin-bottom: 2rem;
    }

    .home-link { opacity: 0.5; }
</style>
