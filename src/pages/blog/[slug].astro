---
import { getCollection, render } from 'astro:content'
import Base from '../../layouts/Base.astro'

export async function getStaticPaths() {
  const posts = await getCollection('blog')
  return posts.map((post) => ({
    params: { slug: post.id.replace(/^\d+_/, '') },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content } = await render(post)

const title =
  post.data.title ||
  post.body
    ?.split('\n')
    .find((l: string) => l.startsWith('# '))
    ?.replace(/^#\s*/, '') ||
  'Untitled'
const description = post.data.description || `${title} — by janice quach`
const date = new Date(post.data.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})
---

<Base title={`${title} — janice quach`} description={description}>
  <main class="blog-post">
    <header class="post-header">
      <a href="/blog" class="back-link">← writing</a>
      <time class="post-date">{date}</time>
      <h1>{title}</h1>
    </header>

    <article class="prose">
      <Content />
    </article>

    <script>
      ;(() => {
        let maxScroll = 0
        const start = Date.now()
        const slug = window.location.pathname.replace(/^\/blog\//, '').replace(/\/$/, '')

        const track = () => {
          const doc = document.documentElement
          const scrollTop = window.scrollY
          const scrollHeight = doc.scrollHeight - doc.clientHeight
          if (scrollHeight > 0) {
            maxScroll = Math.max(maxScroll, Math.round((scrollTop / scrollHeight) * 100))
          }
        }

        const send = () => {
          const time = Math.round((Date.now() - start) / 1000)
          if (time < 2) return
          navigator.sendBeacon(
            '/api/beacon',
            JSON.stringify({
              slug,
              scroll: maxScroll,
              time,
              referrer: document.referrer || '',
            })
          )
        }

        window.addEventListener('scroll', track, { passive: true })
        document.addEventListener('visibilitychange', () => {
          if (document.visibilityState === 'hidden') send()
        })
      })()
    </script>

    <footer class="post-footer">
      <a href="/blog" class="back-link">← all writing</a>
    </footer>
  </main>
</Base>

<style>
  .blog-post {
    max-width: 640px;
    margin: 0 auto;
    padding: 5rem 2rem 6rem;
  }

  .post-header {
    margin-bottom: 3.5rem;
  }

  .back-link {
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    color: rgba(42, 37, 32, 0.4);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: rgba(42, 37, 32, 0.75);
  }

  .post-date {
    display: block;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    color: rgba(42, 37, 32, 0.4);
    margin-top: 1.5rem;
  }

  h1 {
    font-family: "DM Serif Display", Georgia, serif;
    font-size: 2rem;
    font-weight: 400;
    color: #2a2520;
    margin-top: 0.5rem;
    letter-spacing: -0.02em;
    line-height: 1.25;
  }

  /* prose */
  .prose {
    font-size: 1rem;
    line-height: 1.85;
    color: rgba(42, 37, 32, 0.85);
  }

  .prose :global(p) {
    margin-bottom: 1.6rem;
  }

  .prose :global(p:last-child) {
    margin-bottom: 0;
  }

  .prose :global(h2) {
    font-family: "DM Serif Display", Georgia, serif;
    font-size: 1.3rem;
    font-weight: 400;
    color: #2a2520;
    margin: 3rem 0 1rem;
    letter-spacing: -0.01em;
  }

  .prose :global(h1) {
    display: none;
  }

  .prose :global(a) {
    color: #2a2520;
    text-underline-offset: 3px;
    text-decoration-color: rgba(42, 37, 32, 0.3);
  }

  .prose :global(a:hover) {
    text-decoration-color: rgba(42, 37, 32, 0.7);
  }

  .prose :global(blockquote) {
    border-left: 2px solid rgba(42, 37, 32, 0.15);
    padding-left: 1.25rem;
    margin: 2rem 0;
    color: rgba(42, 37, 32, 0.6);
    font-style: italic;
  }

  .prose :global(em) {
    font-style: italic;
  }

  .prose :global(strong) {
    font-weight: 500;
    color: #2a2520;
  }

  .post-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(42, 37, 32, 0.1);
  }
</style>
