---
import CreateMorphDiagram from '../components/CreateMorphDiagram.astro'
import PageFooter from '../components/PageFooter.astro'
import Base from '../layouts/Base.astro'
---
<Base title="create — janice quach" description="Design is how it works. Visual craft, UI, diagrams, and systems by Janice Quach.">
    <div class="bg-layer" id="createBgLayer"></div>
    <a class="back-btn" href="/" aria-label="Back to home">← back</a>

    <div class="diagram-fixed" id="createDiagramFixed">
        <div class="orb orb-a" aria-hidden="true"></div>
        <div class="orb orb-b" aria-hidden="true"></div>
        <CreateMorphDiagram />
    </div>

    <div class="text-bubble" id="createTextBubble">
        <p class="section-num" id="createBubbleNum">create</p>
        <h2 id="createBubbleHeadline">Design is how it works</h2>
        <p id="createBubbleBody">I'm a visual thinker. When something's complex, my instinct is to draw it — not explain it. This page is proof.</p>
    </div>

    <div class="scroll-track">
        <div class="scroll-section" data-section="0"></div>
        <div class="scroll-section" data-section="1"></div>
        <div class="scroll-section" data-section="2"></div>
        <div class="scroll-section" data-section="3"></div>
        <div class="scroll-section" data-section="4"></div>
    </div>

    <section class="work-samples">
        <article class="work-card">
            <div class="work-card-image">
                <img src="/work/systems.svg" alt="Design systems work: token architecture, component structure, and pattern relationships" width="1200" height="800" loading="lazy">
            </div>
            <div class="work-card-text">
                <p class="work-label">01 systems</p>
                <h3>Build the system, not the screen</h3>
                <p>Tokens, components, patterns. The invisible architecture that makes every future screen faster to build and harder to break. When the system is right, designers stop fighting the tool and start using it.</p>
            </div>
        </article>

        <article class="work-card work-card-reverse">
            <div class="work-card-image">
                <img src="/work/product.svg" alt="Product interface work: navigation, content areas, and interaction patterns" width="1200" height="800" loading="lazy">
            </div>
            <div class="work-card-text">
                <p class="work-label">02 product</p>
                <h3>Complexity made invisible</h3>
                <p>The best interfaces feel obvious. That takes research, trade-offs, and a hundred decisions no one will ever notice. Every screen here started as a hard problem that needed to feel easy.</p>
            </div>
        </article>

        <article class="work-card">
            <div class="work-card-image">
                <img src="/work/visual.svg" alt="Visual thinking work: relationship diagrams, frameworks, and spatial reasoning" width="1200" height="800" loading="lazy">
            </div>
            <div class="work-card-text">
                <p class="work-label">03 visual</p>
                <h3>Draw it to see it</h3>
                <p>When something is complex, drawing it usually shows me what words could not. Diagrams, frameworks, spatial maps. Not decoration. How I think.</p>
            </div>
        </article>
    </section>

    <div class="detail-overlay" id="detailOverlay" aria-hidden="true" role="dialog" aria-modal="true">
        <button class="detail-close" id="detailClose" aria-label="Close detail view">&times;</button>
        <div class="detail-content" id="detailContent">
            <div class="detail-image" id="detailImage"></div>
            <div class="detail-text" id="detailText"></div>
        </div>
    </div>

    <PageFooter theme="create" />
</Base>

<style>
    .back-btn {
        position: fixed;
        top: 2rem;
        left: 2rem;
        z-index: 200;
        font-family: 'Inter', sans-serif;
        font-size: 0.75rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: rgba(0,0,0,0.4);
        background: rgba(255,255,255,0.6);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(0,0,0,0.08);
        padding: 0.6rem 1.2rem;
        border-radius: 30px;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .back-btn:hover {
        color: rgba(0,0,0,0.7);
        background: rgba(255,255,255,0.85);
    }

    .bg-layer {
        position: fixed;
        inset: 0;
        z-index: -1;
        background: #e8e4de;
        will-change: background-color;
    }

    .diagram-fixed {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1;
        pointer-events: none;
        overflow: hidden;
        transition: opacity 0.4s ease;
    }

    .orb-a {
        width: 450px; height: 450px;
        background: radial-gradient(circle at 50% 40%, rgba(220, 200, 170, 0.4), transparent 70%);
        top: -80px; right: -80px;
    }

    .orb-b {
        width: 380px; height: 380px;
        background: radial-gradient(circle at 40% 60%, rgba(200, 180, 160, 0.3), transparent 70%);
        bottom: -60px; left: -60px;
    }

    .text-bubble {
        position: fixed;
        bottom: 3rem;
        right: 3rem;
        z-index: 10;
        max-width: 400px;
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(58, 53, 48, 0.08);
        border-radius: 20px;
        padding: 2rem 2.4rem;
        pointer-events: none;
        transition: opacity 0.3s ease;
    }

    .section-num {
        font-size: 0.6rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(58, 53, 48, 0.3);
        margin-bottom: 1rem;
    }

    .text-bubble h2 {
        font-size: 1.8rem;
        line-height: 1.15;
        margin-bottom: 0.8rem;
        color: #3a3530;
    }

    .text-bubble p {
        font-size: 0.85rem;
        font-weight: 300;
        line-height: 1.85;
        color: #5a5550;
    }

    .scroll-track {
        position: relative;
        z-index: 0;
    }

    .scroll-section {
        height: 150vh;
    }

    .work-samples {
        position: relative;
        z-index: 2;
        padding: 8rem 2rem 4rem;
        max-width: 1000px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 8rem;
    }

    .work-card {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 3rem;
        align-items: center;
    }

    .work-card-reverse {
        grid-template-columns: 1fr 1.2fr;
    }

    .work-card-reverse .work-card-image {
        order: 2;
    }

    .work-card-reverse .work-card-text {
        order: 1;
    }

    .work-card-image {
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid rgba(58, 53, 48, 0.06);
    }

    .work-card-image img {
        display: block;
        width: 100%;
        height: auto;
    }

    .work-label {
        font-size: 0.6rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(58, 53, 48, 0.3);
        margin-bottom: 1rem;
    }

    .work-card h3 {
        font-size: 1.5rem;
        line-height: 1.2;
        color: #3a3530;
        margin-bottom: 1rem;
    }

    .work-card p:last-child {
        font-size: 0.85rem;
        font-weight: 300;
        line-height: 1.85;
        color: #5a5550;
    }

    .work-card {
        opacity: 0;
        transform: translateY(40px);
        transition: opacity 0.7s ease, transform 0.7s ease;
    }

    .work-card.visible {
        opacity: 1;
        transform: translateY(0);
    }

    @media (prefers-reduced-motion: reduce) {
        .work-card {
            opacity: 1;
            transform: none;
            transition: none;
        }
    }

    .work-card {
        cursor: pointer;
    }

    .detail-overlay {
        position: fixed;
        inset: 0;
        z-index: 500;
        background: rgba(42, 37, 32, 0.85);
        backdrop-filter: blur(20px);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.35s ease;
    }

    .detail-overlay.open {
        opacity: 1;
        pointer-events: auto;
    }

    .detail-close {
        position: absolute;
        top: 1.5rem;
        right: 1.5rem;
        z-index: 510;
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.15);
        color: rgba(255, 255, 255, 0.8);
        font-size: 1.5rem;
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s ease;
    }

    .detail-close:hover {
        background: rgba(255, 255, 255, 0.25);
    }

    .detail-content {
        max-width: 900px;
        width: 90vw;
        display: grid;
        grid-template-columns: 1.4fr 1fr;
        gap: 3rem;
        align-items: center;
        transform: translateY(16px);
        transition: transform 0.35s ease;
    }

    .detail-overlay.open .detail-content {
        transform: translateY(0);
    }

    .detail-image img {
        display: block;
        width: 100%;
        height: auto;
        border-radius: 12px;
    }

    .detail-text .work-label {
        color: rgba(255, 255, 255, 0.35);
    }

    .detail-text h3 {
        font-size: 1.8rem;
        line-height: 1.2;
        color: #f4f1eb;
        margin-bottom: 1rem;
    }

    .detail-text p:last-child {
        font-size: 0.9rem;
        font-weight: 300;
        line-height: 1.85;
        color: rgba(244, 241, 235, 0.7);
    }

    @media (max-width: 900px) {
        .detail-content {
            grid-template-columns: 1fr;
            gap: 2rem;
            max-height: 85vh;
            overflow-y: auto;
            padding: 1rem;
        }
    }

    @media (max-width: 900px) {
        .text-bubble {
            right: 1.5rem;
            left: 1.5rem;
            bottom: 2rem;
            max-width: none;
        }

        .work-card,
        .work-card-reverse {
            grid-template-columns: 1fr;
        }

        .work-card-reverse .work-card-image,
        .work-card-reverse .work-card-text {
            order: unset;
        }

        .work-samples {
            gap: 5rem;
            padding: 5rem 1.5rem 3rem;
        }
    }
</style>

<script>
    const textData = [
        {
            num: 'create',
            headline: 'Design is how it works',
            body: 'I\'m a visual thinker. When something\'s complex, my instinct is to draw it — not explain it. This page is proof.'
        },
        {
            num: '01 — systems',
            headline: 'Build the system, not the screen',
            body: 'Components, tokens, patterns — the invisible architecture that makes every future screen faster to build and harder to break.'
        },
        {
            num: '02 — product',
            headline: 'Complexity made invisible',
            body: 'The best interfaces feel obvious. That takes research, trade-offs, and a hundred decisions no one will ever notice.'
        },
        {
            num: '03 — visual',
            headline: 'Draw it to see it',
            body: 'When something\'s complex, drawing it usually shows me what words couldn\'t. Diagrams aren\'t decoration — they\'re how I think.'
        },
        {
            num: '04 — craft',
            headline: 'Make it real',
            body: 'Make as much as possible. Tend to chaos and see what survives. The best work isn\'t planned — it\'s the thing that refused to die.'
        }
    ];

    const bubble = document.getElementById('createTextBubble') as HTMLElement;
    const bubbleNum = document.getElementById('createBubbleNum') as HTMLElement;
    const bubbleH2 = document.getElementById('createBubbleHeadline') as HTMLElement;
    const bubbleBody = document.getElementById('createBubbleBody') as HTMLElement;
    const diagramFixed = document.getElementById('createDiagramFixed') as HTMLElement;
    const scrollTrack = document.querySelector('.scroll-track') as HTMLElement;

    let currentSection = 0;
    let ticking = false;

    function getActiveSection(): number {
        const section = document.querySelector('.scroll-section') as HTMLElement;
        const sectionHeight = section.offsetHeight;
        return Math.min(Math.round(window.scrollY / sectionHeight), textData.length - 1);
    }

    function onScroll() {
        if (!ticking) {
            ticking = true;
            requestAnimationFrame(() => {
                const active = getActiveSection();
                if (active !== currentSection) {
                    currentSection = active;
                    const data = textData[active];
                    bubble.style.opacity = '0';
                    setTimeout(() => {
                        bubbleNum.textContent = data.num;
                        bubbleH2.textContent = data.headline;
                        bubbleBody.textContent = data.body;
                        bubble.style.opacity = '1';
                    }, 150);
                }

                const trackBottom = scrollTrack.getBoundingClientRect().bottom;
                const pastTrack = trackBottom < window.innerHeight * 0.5;
                diagramFixed.style.opacity = pastTrack ? '0' : '1';
                bubble.style.display = pastTrack ? 'none' : '';

                ticking = false;
            });
        }
    }

    window.addEventListener('scroll', onScroll, { passive: true });

    const cards = document.querySelectorAll<HTMLElement>('.work-card');
    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                    observer.unobserve(entry.target);
                }
            });
        },
        { threshold: 0.15 }
    );
    cards.forEach((card) => observer.observe(card));

    const overlay = document.getElementById('detailOverlay') as HTMLElement;
    const detailImage = document.getElementById('detailImage') as HTMLElement;
    const detailText = document.getElementById('detailText') as HTMLElement;
    const detailClose = document.getElementById('detailClose') as HTMLElement;

    function openDetail(card: HTMLElement) {
        const img = card.querySelector('.work-card-image')?.innerHTML ?? '';
        const text = card.querySelector('.work-card-text')?.innerHTML ?? '';
        detailImage.innerHTML = img;
        detailText.innerHTML = text;
        overlay.classList.add('open');
        overlay.setAttribute('aria-hidden', 'false');
        detailClose.focus();
    }

    function closeDetail() {
        overlay.classList.remove('open');
        overlay.setAttribute('aria-hidden', 'true');
    }

    cards.forEach((card) => {
        card.addEventListener('click', () => openDetail(card));
        card.addEventListener('keydown', (e: KeyboardEvent) => {
            if (e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                openDetail(card);
            }
        });
        card.setAttribute('tabindex', '0');
        card.setAttribute('role', 'button');
        card.setAttribute('aria-label', card.querySelector('h3')?.textContent ?? 'View detail');
    });

    detailClose.addEventListener('click', closeDetail);
    overlay.addEventListener('click', (e: MouseEvent) => {
        if (e.target === overlay) closeDetail();
    });
    document.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Escape' && overlay.classList.contains('open')) closeDetail();
    });
</script>
