---
import CreateMorphDiagram from "../components/CreateMorphDiagram.astro";
import PageFooter from "../components/PageFooter.astro";
import Base from "../layouts/Base.astro";
---
<Base title="create — Janice Quach" description="Design is how it works. Visual craft, UI, diagrams, and systems by Janice Quach.">
    <div class="bg-layer" id="createBgLayer"></div>
    <a class="back-btn" href="/">← back</a>

    <div class="diagram-fixed" id="createDiagramFixed">
        <div class="orb orb-a"></div>
        <div class="orb orb-b"></div>
        <CreateMorphDiagram />
    </div>

    <div class="text-bubble" id="createTextBubble">
        <p class="section-num" id="createBubbleNum">create</p>
        <h2 id="createBubbleHeadline">Design is how it works</h2>
        <p id="createBubbleBody">I'm a visual thinker. When something's complex, my instinct is to draw it — not explain it. This page is proof.</p>
    </div>

    <div class="scroll-track">
        <div class="scroll-section" data-section="0"></div>
        <div class="scroll-section" data-section="1"></div>
        <div class="scroll-section" data-section="2"></div>
        <div class="scroll-section" data-section="3"></div>
        <div class="scroll-section" data-section="4"></div>
    </div>

    <PageFooter theme="create" />
</Base>

<style>
    .back-btn {
        position: fixed;
        top: 2rem;
        left: 2rem;
        z-index: 200;
        font-family: 'Inter', sans-serif;
        font-size: 0.75rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: rgba(0,0,0,0.4);
        background: rgba(255,255,255,0.6);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(0,0,0,0.08);
        padding: 0.6rem 1.2rem;
        border-radius: 30px;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .back-btn:hover {
        color: rgba(0,0,0,0.7);
        background: rgba(255,255,255,0.85);
    }

    .bg-layer {
        position: fixed;
        inset: 0;
        z-index: -1;
        background: #e8e4de;
        will-change: background-color;
    }

    .diagram-fixed {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1;
        pointer-events: none;
        overflow: hidden;
        transition: opacity 0.4s ease;
    }

    .orb-a {
        width: 450px; height: 450px;
        background: radial-gradient(circle at 50% 40%, rgba(220, 200, 170, 0.4), transparent 70%);
        top: -80px; right: -80px;
    }

    .orb-b {
        width: 380px; height: 380px;
        background: radial-gradient(circle at 40% 60%, rgba(200, 180, 160, 0.3), transparent 70%);
        bottom: -60px; left: -60px;
    }

    .text-bubble {
        position: fixed;
        bottom: 3rem;
        right: 3rem;
        z-index: 10;
        max-width: 400px;
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(58, 53, 48, 0.08);
        border-radius: 20px;
        padding: 2rem 2.4rem;
        pointer-events: none;
        transition: opacity 0.3s ease;
    }

    .section-num {
        font-size: 0.6rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(58, 53, 48, 0.3);
        margin-bottom: 1rem;
    }

    .text-bubble h2 {
        font-size: 1.8rem;
        line-height: 1.15;
        margin-bottom: 0.8rem;
        color: #3a3530;
    }

    .text-bubble p {
        font-size: 0.85rem;
        font-weight: 300;
        line-height: 1.85;
        color: #5a5550;
    }

    .scroll-track {
        position: relative;
        z-index: 0;
    }

    .scroll-section {
        height: 150vh;
    }

    @media (max-width: 900px) {
        .text-bubble {
            right: 1.5rem;
            left: 1.5rem;
            bottom: 2rem;
            max-width: none;
        }
    }
</style>

<script>
    const textData = [
        {
            num: 'create',
            headline: 'Design is how it works',
            body: 'I\'m a visual thinker. When something\'s complex, my instinct is to draw it — not explain it. This page is proof.'
        },
        {
            num: '01 — systems',
            headline: 'Build the system, not the screen',
            body: 'Components, tokens, patterns — the invisible architecture that makes every future screen faster to build and harder to break.'
        },
        {
            num: '02 — product',
            headline: 'Complexity made invisible',
            body: 'The best interfaces feel obvious. That takes research, trade-offs, and a hundred decisions no one will ever notice.'
        },
        {
            num: '03 — visual',
            headline: 'Draw it to see it',
            body: 'When something\'s complex, drawing it usually shows me what words couldn\'t. Diagrams aren\'t decoration — they\'re how I think.'
        },
        {
            num: '04 — craft',
            headline: 'The work speaks',
            body: 'You don\'t need a case study when the craft is visible. This site is the portfolio piece.'
        }
    ];

    const bubble = document.getElementById('createTextBubble') as HTMLElement;
    const bubbleNum = document.getElementById('createBubbleNum') as HTMLElement;
    const bubbleH2 = document.getElementById('createBubbleHeadline') as HTMLElement;
    const bubbleBody = document.getElementById('createBubbleBody') as HTMLElement;
    const diagramFixed = document.getElementById('createDiagramFixed') as HTMLElement;
    const scrollTrack = document.querySelector('.scroll-track') as HTMLElement;

    let currentSection = 0;
    let ticking = false;

    function getActiveSection(): number {
        const section = document.querySelector('.scroll-section') as HTMLElement;
        const sectionHeight = section.offsetHeight;
        return Math.min(Math.round(window.scrollY / sectionHeight), textData.length - 1);
    }

    function onScroll() {
        if (!ticking) {
            ticking = true;
            requestAnimationFrame(() => {
                const active = getActiveSection();
                if (active !== currentSection) {
                    currentSection = active;
                    const data = textData[active];
                    bubble.style.opacity = '0';
                    setTimeout(() => {
                        bubbleNum.textContent = data.num;
                        bubbleH2.textContent = data.headline;
                        bubbleBody.textContent = data.body;
                        bubble.style.opacity = '1';
                    }, 150);
                }

                const trackBottom = scrollTrack.getBoundingClientRect().bottom;
                const pastTrack = trackBottom < window.innerHeight * 0.5;
                diagramFixed.style.opacity = pastTrack ? '0' : '1';
                bubble.style.display = pastTrack ? 'none' : '';

                ticking = false;
            });
        }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
</script>
