---
import PageFooter from "../components/PageFooter.astro";
import ScrollMorphDiagram from "../components/ScrollMorphDiagram.astro";
import Base from "../layouts/Base.astro";
---
<Base title="think — janice quach" description="clarity over cleverness. how janice quach thinks about design, systems, and trade-offs.">
    <div class="bg-layer" id="bgLayer"></div>
    <a class="back-btn" href="/">← back</a>
    <div class="page">
        <section class="scroll-section" data-section="0">
            <div class="diagram-area">
                <div class="orb orb-a"></div>
                <div class="orb orb-b"></div>
                <ScrollMorphDiagram />
            </div>
            <div class="text-bubble">
                <p class="section-num">think</p>
                <h2>clarity over cleverness</h2>
                <p>my brain works like this — ideas start scattered, and the job is finding the structure underneath. whether it's research, design, or strategy, i'm drawn to simple rules that make every decision after them easier.</p>
            </div>
        </section>
        <section class="scroll-section" data-section="1">
            <div class="text-bubble">
                <p class="section-num">01 — structure</p>
                <h2>structure creates speed</h2>
                <p>good structure means less time navigating, more time making. i sit inside the product team, not next to it — so the frameworks i build have to work for engineers and PMs too, not just designers.</p>
            </div>
        </section>
        <section class="scroll-section" data-section="2">
            <div class="text-bubble">
                <p class="section-num">02 — systems</p>
                <h2>build once, reuse often</h2>
                <p>i think in systems — not because they're elegant, but because the right one means the next person doesn't have to solve the same problem again.</p>
            </div>
        </section>
        <section class="scroll-section" data-section="3">
            <div class="text-bubble">
                <p class="section-num">03 — trade-offs</p>
                <h2>intentional trade-offs</h2>
                <p>every decision optimises for something and sacrifices something else. i'd rather name that out loud than hide behind "best practice." what's the trade-off? what are we giving up? if we can't answer that, we haven't actually decided anything.</p>
            </div>
        </section>
        <section class="scroll-section" data-section="4">
            <div class="text-bubble">
                <p class="section-num">04 — intent</p>
                <h2>quality reflects intent</h2>
                <p>you can feel when someone cared about the thing they made. the best work feels obvious — not because it's simple, but because someone made the complexity invisible.</p>
            </div>
        </section>
    </div>
    <PageFooter theme="think" />
</Base>

<style>
    .back-btn {
        position: fixed;
        top: 2rem;
        left: 2rem;
        z-index: 200;
        font-family: 'Inter', sans-serif;
        font-size: 0.75rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: rgba(0,0,0,0.4);
        background: rgba(255,255,255,0.6);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(0,0,0,0.08);
        padding: 0.6rem 1.2rem;
        border-radius: 30px;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .back-btn:hover {
        color: rgba(0,0,0,0.7);
        background: rgba(255,255,255,0.85);
    }

    .bg-layer {
        position: fixed;
        inset: 0;
        z-index: -1;
        background: #c8d5c0;
        will-change: background-color;
    }

    .page {
        position: relative;
    }

    .scroll-section {
        min-height: 100vh;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .diagram-area {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: visible;
    }

    .orb-a {
        width: 500px; height: 500px;
        background: radial-gradient(circle at 40% 40%, rgba(168, 190, 140, 0.4), transparent 70%);
        top: -120px; right: -120px;
    }

    .orb-b {
        width: 400px; height: 400px;
        background: radial-gradient(circle at 60% 60%, rgba(200, 220, 180, 0.3), transparent 70%);
        bottom: -100px; left: -80px;
    }

    .text-bubble {
        position: fixed;
        bottom: 3rem;
        right: 3rem;
        z-index: 10;
        max-width: 400px;
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(42, 58, 37, 0.08);
        border-radius: 20px;
        padding: 2rem 2.4rem;
        pointer-events: none;
        transition: opacity 0.4s ease;
    }

    .scroll-section:not(:first-child) .text-bubble {
        display: none;
    }

    .section-num {
        font-size: 0.6rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(42, 58, 37, 0.3);
        margin-bottom: 1rem;
    }

    .text-bubble h2 {
        font-size: 1.8rem;
        line-height: 1.15;
        margin-bottom: 0.8rem;
        color: #1e2e1a;
    }

    .text-bubble p {
        font-size: 0.85rem;
        font-weight: 300;
        line-height: 1.85;
        color: #3d4d38;
    }

    @media (max-width: 900px) {
        .text-bubble {
            right: 1.5rem;
            left: 1.5rem;
            bottom: 2rem;
            max-width: none;
        }
    }
</style>

<script>
    const textData = [
        {
            num: 'think',
            headline: 'clarity over cleverness',
            body: 'my brain works like this — ideas start scattered, and the job is finding the structure underneath. whether it\'s research, design, or strategy, i\'m drawn to simple rules that make every decision after them easier.'
        },
        {
            num: '01 — structure',
            headline: 'structure creates speed',
            body: 'good structure means less time navigating, more time making. i sit inside the product team, not next to it — so the frameworks i build have to work for engineers and PMs too, not just designers.'
        },
        {
            num: '02 — systems',
            headline: 'build once, reuse often',
            body: 'i think in systems — not because they\'re elegant, but because the right one means the next person doesn\'t have to solve the same problem again.'
        },
        {
            num: '03 — trade-offs',
            headline: 'intentional trade-offs',
            body: 'every decision optimises for something and sacrifices something else. i\'d rather name that out loud than hide behind "best practice." what\'s the trade-off? what are we giving up? if we can\'t answer that, we haven\'t actually decided anything.'
        },
        {
            num: '04 — intent',
            headline: 'quality reflects intent',
            body: 'you can feel when someone cared about the thing they made. the best work feels obvious — not because it\'s simple, but because someone made the complexity invisible.'
        }
    ];

    const bubble = document.querySelector('.text-bubble') as HTMLElement;
    const bubbleNum = bubble.querySelector('.section-num') as HTMLElement;
    const bubbleH2 = bubble.querySelector('h2') as HTMLElement;
    const bubbleP = bubble.querySelector('p:last-child') as HTMLElement;
    const sections = document.querySelectorAll('.scroll-section');

    // Keep only the first bubble visible, remove duplicates from other sections
    sections.forEach((sec, i) => {
        if (i > 0) {
            const extraBubble = sec.querySelector('.text-bubble');
            if (extraBubble) extraBubble.remove();
        }
    });

    // Make the bubble position:fixed and always visible
    bubble.style.position = 'fixed';

    function getActiveSection(): number {
        const scrollY = window.scrollY;
        const vh = window.innerHeight;
        return Math.min(Math.round(scrollY / vh), textData.length - 1);
    }

    let currentSection = -1;
    let ticking = false;

    function onScroll() {
        if (!ticking) {
            ticking = true;
            requestAnimationFrame(() => {
                const active = getActiveSection();
                if (active !== currentSection) {
                    currentSection = active;
                    const data = textData[active];
                    bubble.style.opacity = '0';
                    setTimeout(() => {
                        bubbleNum.textContent = data.num;
                        bubbleH2.textContent = data.headline;
                        bubbleP.textContent = data.body;
                        bubble.style.opacity = '1';
                    }, 200);
                }
                ticking = false;
            });
        }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    // Initialize
    currentSection = 0;
    bubble.style.opacity = '1';
</script>
