---
import PageFooter from '../components/PageFooter.astro'
import ScrollMorphDiagram from '../components/ScrollMorphDiagram.astro'
import Base from '../layouts/Base.astro'
---
<Base title="think — janice quach" description="Clarity over cleverness. How Janice Quach thinks about design, systems, and trade-offs.">
    <div class="bg-layer" id="bgLayer"></div>
    <a class="back-btn" href="/" aria-label="Back to home">← back</a>

    <!-- Fixed diagram in viewport centre -->
    <div class="diagram-fixed" id="diagramFixed">
        <div class="orb orb-a" aria-hidden="true"></div>
        <div class="orb orb-b" aria-hidden="true"></div>
        <ScrollMorphDiagram />
    </div>

    <!-- Fixed text bubble bottom-right -->
    <div class="text-bubble" id="textBubble">
        <p class="section-num" id="bubbleNum">think</p>
        <h2 id="bubbleHeadline">Clarity over cleverness</h2>
        <p id="bubbleBody">My brain works like this — ideas start scattered, and the job is finding the structure underneath. Whether it's research, design, or strategy, I'm drawn to simple rules that make every decision after them easier.</p>
    </div>

    <!-- Scroll spacers — one per section to drive scroll progress -->
    <div class="scroll-track">
        <div class="scroll-section" data-section="0"></div>
        <div class="scroll-section" data-section="1"></div>
        <div class="scroll-section" data-section="2"></div>
        <div class="scroll-section" data-section="3"></div>
        <div class="scroll-section" data-section="4"></div>
    </div>

    <PageFooter theme="think" />
</Base>

<style>
    .back-btn {
        position: fixed;
        top: 2rem;
        left: 2rem;
        z-index: 200;
        font-family: 'Inter', sans-serif;
        font-size: 0.75rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: rgba(0,0,0,0.4);
        background: rgba(255,255,255,0.6);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(0,0,0,0.08);
        padding: 0.6rem 1.2rem;
        border-radius: 30px;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .back-btn:hover {
        color: rgba(0,0,0,0.7);
        background: rgba(255,255,255,0.85);
    }

    .bg-layer {
        position: fixed;
        inset: 0;
        z-index: -1;
        background: #c8d5c0;
        will-change: background-color;
    }

    .diagram-fixed {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1;
        pointer-events: none;
        overflow: hidden;
        transition: opacity 0.4s ease;
    }

    .orb-a {
        width: 500px; height: 500px;
        background: radial-gradient(circle at 40% 40%, rgba(168, 190, 140, 0.4), transparent 70%);
        top: -120px; right: -120px;
    }

    .orb-b {
        width: 400px; height: 400px;
        background: radial-gradient(circle at 60% 60%, rgba(200, 220, 180, 0.3), transparent 70%);
        bottom: -100px; left: -80px;
    }

    .text-bubble {
        position: fixed;
        bottom: 3rem;
        right: 3rem;
        z-index: 10;
        max-width: 400px;
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(42, 58, 37, 0.08);
        border-radius: 20px;
        padding: 2rem 2.4rem;
        pointer-events: none;
        transition: opacity 0.3s ease;
    }

    .section-num {
        font-size: 0.6rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(42, 58, 37, 0.3);
        margin-bottom: 1rem;
    }

    .text-bubble h2 {
        font-size: 1.8rem;
        line-height: 1.15;
        margin-bottom: 0.8rem;
        color: #1e2e1a;
    }

    .text-bubble p {
        font-size: 0.85rem;
        font-weight: 300;
        line-height: 1.85;
        color: #3d4d38;
    }

    .scroll-track {
        position: relative;
        z-index: 0;
    }

    .scroll-section {
        height: 150vh;
    }

    @media (max-width: 900px) {
        .text-bubble {
            right: 1.5rem;
            left: 1.5rem;
            bottom: 2rem;
            max-width: none;
        }
    }
</style>

<script>
    const textData = [
        {
            num: 'think',
            headline: 'Clarity over cleverness',
            body: 'My brain works like this — ideas start scattered, and the job is finding the structure underneath. Whether it\'s research, design, or strategy, I\'m drawn to simple rules that make every decision after them easier.'
        },
        {
            num: '01 — structure',
            headline: 'Structure creates speed',
            body: 'Good structure means less time navigating, more time making. I sit inside the product team, not next to it — so the frameworks I build have to work for engineers and PMs too, not just designers.'
        },
        {
            num: '02 — systems',
            headline: 'Build once, reuse often',
            body: 'I think in systems — not because they\'re elegant, but because the right one means the next person doesn\'t have to solve the same problem again.'
        },
        {
            num: '03 — trade-offs',
            headline: 'Intentional trade-offs',
            body: 'Every decision optimises for something and sacrifices something else. I\'d rather name that out loud than hide behind "best practice." What\'s the trade-off? What are we giving up? If we can\'t answer that, we haven\'t actually decided anything.'
        },
        {
            num: '04 — intent',
            headline: 'Quality reflects intent',
            body: 'You can feel when someone cared about the thing they made. The best work feels obvious — not because it\'s simple, but because someone made the complexity invisible.'
        }
    ];

    const bubble = document.getElementById('textBubble') as HTMLElement;
    const bubbleNum = document.getElementById('bubbleNum') as HTMLElement;
    const bubbleH2 = document.getElementById('bubbleHeadline') as HTMLElement;
    const bubbleBody = document.getElementById('bubbleBody') as HTMLElement;
    const diagramFixed = document.getElementById('diagramFixed') as HTMLElement;
    const scrollTrack = document.querySelector('.scroll-track') as HTMLElement;

    let currentSection = 0;
    let ticking = false;

    function getActiveSection(): number {
        const section = document.querySelector('.scroll-section') as HTMLElement;
        const sectionHeight = section.offsetHeight;
        return Math.min(Math.round(window.scrollY / sectionHeight), textData.length - 1);
    }

    function onScroll() {
        if (!ticking) {
            ticking = true;
            requestAnimationFrame(() => {
                const active = getActiveSection();
                if (active !== currentSection) {
                    currentSection = active;
                    const data = textData[active];
                    bubble.style.opacity = '0';
                    setTimeout(() => {
                        bubbleNum.textContent = data.num;
                        bubbleH2.textContent = data.headline;
                        bubbleBody.textContent = data.body;
                        bubble.style.opacity = '1';
                    }, 150);
                }

                // Hide fixed elements when scrolled past the scroll track
                const trackBottom = scrollTrack.getBoundingClientRect().bottom;
                const pastTrack = trackBottom < window.innerHeight * 0.5;
                diagramFixed.style.opacity = pastTrack ? '0' : '1';
                bubble.style.display = pastTrack ? 'none' : '';

                ticking = false;
            });
        }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
</script>
