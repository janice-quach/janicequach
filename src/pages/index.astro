---
import Base from "../layouts/Base.astro";
---
<Base title="janice quach">
    <div class="hub">
        <div class="orb orb-1" aria-hidden="true"></div>
        <div class="orb orb-2" aria-hidden="true"></div>
        <div class="orb orb-3" aria-hidden="true"></div>
        <div class="hub-content">
            <h1>janice<br>quach</h1>
            <p class="intro">
                Head of design & research, embedded in product.
                I won my first design job through a uni competition and never left —
                started as the only designer, built a team of 8.
                I care about clarity, honest trade-offs, and teams that think for themselves.
            </p>
            <nav class="tags">
                <a class="tag tag-think" href="/think"><span>think</span></a>
                <a class="tag tag-lead" href="/lead"><span>lead</span></a>
                <a class="tag tag-create" href="/create"><span>create</span></a>
            </nav>
        </div>
    </div>
</Base>

<style>
    .hub {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        position: relative;
        padding: 4rem 2rem;
    }

    .orb-1 {
        width: 600px; height: 600px;
        background: radial-gradient(circle at 30% 40%, rgba(180, 195, 176, 0.35), transparent 70%);
        top: -200px; right: -200px;
    }

    .orb-2 {
        width: 500px; height: 500px;
        background: radial-gradient(circle at 60% 50%, rgba(195, 210, 225, 0.3), transparent 70%);
        bottom: -150px; left: -150px;
    }

    .orb-3 {
        width: 300px; height: 300px;
        background: radial-gradient(circle at 50% 50%, rgba(220, 200, 180, 0.25), transparent 70%);
        top: 40%; left: 50%; transform: translateX(-50%);
    }

    .hub-content {
        position: relative;
        z-index: 1;
        text-align: center;
        max-width: 600px;
    }

    .hub-content h1 {
        font-size: 5rem;
        letter-spacing: -0.03em;
        line-height: 1.05;
        color: #1a1a1a;
        margin-bottom: 1.5rem;
    }

    .intro {
        font-size: 1.1rem;
        color: #6b6b6b;
        font-weight: 300;
        max-width: 440px;
        margin: 0 auto 4rem;
    }

    .tags {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .tag {
        font-family: 'DM Serif Display', Georgia, serif;
        font-size: 1.3rem;
        padding: 1rem 2.5rem;
        border: 1px solid rgba(26, 26, 26, 0.15);
        border-radius: 60px;
        background: rgba(255, 255, 255, 0.5);
        backdrop-filter: blur(10px);
        cursor: pointer;
        transition: all 0.4s ease;
        color: #2a2a2a;
        text-decoration: none;
        position: relative;
        overflow: hidden;
    }

    .tag::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 60px;
        opacity: 0;
        transition: opacity 0.4s ease;
    }

    .tag-think::before { background: rgba(200, 213, 192, 0.4); }
    .tag-lead::before { background: rgba(213, 221, 230, 0.4); }
    .tag-create::before { background: rgba(232, 228, 222, 0.4); }

    .tag:hover::before { opacity: 1; }
    .tag:hover {
        border-color: rgba(26, 26, 26, 0.3);
        transform: translateY(-2px);
    }

    .tag span { position: relative; z-index: 1; }

    @media (max-width: 768px) {
        .tags { flex-direction: column; align-items: center; }
        .tag { width: 200px; text-align: center; }
    }
</style>
