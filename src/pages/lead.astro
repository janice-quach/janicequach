---
import LeadMorphDiagram from '../components/LeadMorphDiagram.astro'
import PageFooter from '../components/PageFooter.astro'
import Base from '../layouts/Base.astro'
---
<Base title="lead — janice quach" description="Bring people on the journey. How Janice Quach builds teams that think for themselves.">
    <div class="bg-layer" id="bgLayer"></div>
    <a class="back-btn" href="/" aria-label="Back to home">← back</a>

    <div class="diagram-fixed" id="diagramFixed">
        <div class="orb orb-a" aria-hidden="true"></div>
        <div class="orb orb-b" aria-hidden="true"></div>
        <LeadMorphDiagram />
    </div>

    <div class="text-bubble" id="textBubble">
        <p class="section-num" id="bubbleNum">lead</p>
        <h2 id="bubbleHeadline">Bring people on the journey</h2>
        <p id="bubbleBody">I went from being the only designer to leading a team of 8 inside a product org. Most of what I've learned about leadership, I figured out by doing it — and I'm still figuring it out.</p>
    </div>

    <div class="scroll-track">
        <div class="scroll-section" data-section="0"></div>
        <div class="scroll-section" data-section="1"></div>
        <div class="scroll-section" data-section="2"></div>
        <div class="scroll-section" data-section="3"></div>
        <div class="scroll-section" data-section="4"></div>
    </div>

    <PageFooter theme="lead" />
</Base>

<style>
    .bg-layer {
        position: fixed;
        inset: 0;
        z-index: -1;
        background: #d5dde6;
        will-change: background-color;
    }

    .diagram-fixed {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1;
        pointer-events: none;
        overflow: hidden;
        transition: opacity 0.4s ease;
    }

    .orb-a {
        width: 500px; height: 500px;
        background: radial-gradient(circle at 40% 40%, rgba(130, 160, 200, 0.35), transparent 70%);
        top: -120px; right: -120px;
    }

    .orb-b {
        width: 400px; height: 400px;
        background: radial-gradient(circle at 60% 60%, rgba(160, 185, 220, 0.25), transparent 70%);
        bottom: -100px; left: -80px;
    }

    .text-bubble {
        position: fixed;
        bottom: 3rem;
        right: 3rem;
        z-index: 10;
        max-width: 400px;
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(30, 55, 90, 0.08);
        border-radius: 20px;
        padding: 2rem 2.4rem;
        pointer-events: none;
        transition: opacity 0.3s ease;
    }

    .section-num {
        font-size: 0.6rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(30, 55, 90, 0.3);
        margin-bottom: 1rem;
    }

    .text-bubble h2 {
        font-size: 1.8rem;
        line-height: 1.15;
        margin-bottom: 0.8rem;
        color: #1a2d42;
    }

    .text-bubble p {
        font-size: 0.85rem;
        font-weight: 300;
        line-height: 1.85;
        color: #2e4460;
    }

    .scroll-track {
        position: relative;
        z-index: 0;
    }

    .scroll-section {
        height: 150vh;
    }

    @media (max-width: 900px) {
        .text-bubble {
            right: 1.5rem;
            left: 1.5rem;
            bottom: 2rem;
            max-width: none;
        }
    }
</style>

<script>
    import { initScrollSections } from '../scripts/scroll-sections'

    initScrollSections({
        sectionSelector: '.scroll-section',
        bubbleId: 'textBubble',
        numId: 'bubbleNum',
        headlineId: 'bubbleHeadline',
        bodyId: 'bubbleBody',
        diagramId: 'diagramFixed',
        slides: [
            {
                num: 'lead',
                headline: 'Bring people on the journey',
                body: "I went from being the only designer to leading a team of 8 inside a product org. Most of what I've learned about leadership, I figured out by doing it — and I'm still figuring it out."
            },
            {
                num: '01 — contribution',
                headline: 'Contribution over presence',
                body: "I want people who riff, build, disagree — and come out with something better than any of us would've made alone. What frustrates me is when people don't bring their own thinking. If I'm steering every decision, that's not a team — it's a funnel."
            },
            {
                num: '02 — the gap',
                headline: 'The gap between knowing and doing',
                body: "Everyone nods when you name the pattern. But then what? Knowing something and actually doing it are different things. That gap is where I focus — turning frameworks into real behaviour change, not just shared language."
            },
            {
                num: '03 — decisions',
                headline: 'Decisions like a tree',
                body: "I think about decisions like a tree. Some are leaves — make them yourself. Some are branches — bring them to me. Some are the trunk — that's my call. It's how autonomy works without chaos."
            },
            {
                num: '04 — inception',
                headline: 'Inception over buy-in',
                body: "Buy-in is asking permission after the fact. Inception is building it together from the start. If people helped make the decision, you don't need to sell them on it."
            }
        ]
    })
</script>
